# ==============================================
# DATABASE
# ==============================================
POSTGRES_USER=azov_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=azov_resort

# ==============================================
# DIRECT DOMAIN / TLS
# ==============================================
APP_DOMAIN=your-domain.ru
APP_NETWORK_SUBNET=172.31.250.0/24
APP_UPSTREAM_IP=172.31.250.10
POSTGRES_UPSTREAM_IP=172.31.250.11
NEXT_PUBLIC_SITE_URL=https://your-domain.ru

# ==============================================
# ANALYTICS / SEO
# ==============================================
# Номер счётчика Яндекс.Метрики (metrika.yandex.ru → Настройки → видно в адресе/коде).
# Нужен Яндексу для поведенческих факторов. Если пусто — берётся зашитый дефолт.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# ==============================================
# EMAIL / SMTP
# ==============================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-mail@yandex.ru
SMTP_PASSWORD=APP_PASSWORD
SMTP_FROM="Azov Resort <your-mail@yandex.ru>"

# ==============================================
# VK NOTIFICATIONS (уведомления админу о новых бронях)
# Это НЕ вход через VK, а отправка сообщений админу через сообщество.
# VK_GROUP_TOKEN — ключ доступа сообщества (Управление → Работа с API → Ключи доступа),
#   права: «Сообщения сообщества».
# VK_ADMIN_ID — числовой id пользователя-получателя (узнать: vk.com/id... или через @vkid).
#   Пользователь должен хотя бы раз написать сообществу, иначе VK не даст отправить.
# ==============================================
VK_GROUP_TOKEN=
VK_ADMIN_ID=

# ==============================================
# ADMIN
# ==============================================
ADMIN_EMAIL=admin@your-domain.ru

# ==============================================
# ADMIN PANEL AUTH (separate subdomain)
# ==============================================
# The subdomain hostname for the admin panel (leave empty in development)
# Example: admin.your-domain.ru
ADMIN_DOMAIN=

# JWT signing secret — generate with: openssl rand -base64 48
ADMIN_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Admin login credentials
# Set your desired login name
ADMIN_LOGIN=admin
# Generate bcrypt hash: node scripts/hash-password.js YOUR_PASSWORD
ADMIN_PASSWORD_HASH=CHANGE_ME_RUN_HASH_SCRIPT
