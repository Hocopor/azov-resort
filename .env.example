# ==============================================
# БАЗА ДАННЫХ
# ==============================================
POSTGRES_USER=azov_user
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ
POSTGRES_DB=azov_resort

# ==============================================
# NEXT.JS / AUTH
# ==============================================
NEXTAUTH_URL=https://ВАШ_ДОМЕН.ru
NEXTAUTH_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_32_СИМВОЛА
# Генерация: openssl rand -base64 32

# ==============================================
# CLOUDFLARE TUNNEL
# ==============================================
CLOUDFLARE_TUNNEL_TOKEN=ВАШ_ТОКЕН_ИЗ_CLOUDFLARE_ZERO_TRUST

# ==============================================
# OAUTH — ВКонтакте
# Создайте приложение на: https://vk.com/editapp?act=create
# Тип: Web-сайт, Redirect URI: https://ВАШ_ДОМЕН/api/auth/callback/vk
# ==============================================
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ==============================================
# OAUTH — Яндекс
# Создайте приложение на: https://oauth.yandex.ru/
# Redirect URI: https://ВАШ_ДОМЕН/api/auth/callback/yandex
# ==============================================
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ==============================================
# ЮКАССА (ПЛАТЕЖИ)
# Настройки: https://yookassa.ru/my/merchant/integration/http-notifications
# Webhook URL: https://ВАШ_ДОМЕН/api/payments/webhook
# ==============================================
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ==============================================
# EMAIL (SMTP)
# Для Яндекс.Почты: smtp.yandex.ru:587
# Для Mail.ru: smtp.mail.ru:587
# ==============================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=ваша_почта@yandex.ru
SMTP_PASSWORD=ПАРОЛЬ_ПРИЛОЖЕНИЯ
SMTP_FROM="Отдых на Азове <ваша_почта@yandex.ru>"

# ==============================================
# АДМИНИСТРИРОВАНИЕ
# ==============================================
ADMIN_EMAIL=admin@ВАШ_ДОМЕН.ru
NEXT_PUBLIC_SITE_URL=https://ВАШ_ДОМЕН.ru
