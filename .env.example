# ==============================================
# DATABASE
# ==============================================
POSTGRES_USER=azov_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=azov_resort

# ==============================================
# NEXT.JS / AUTH
# ==============================================
NEXTAUTH_URL=https://your-domain.ru
NEXTAUTH_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_SECRET
# Generate with: openssl rand -base64 32

# ==============================================
# DIRECT DOMAIN / TLS
# ==============================================
APP_DOMAIN=your-domain.ru
APP_NETWORK_SUBNET=172.31.250.0/24
APP_UPSTREAM_IP=172.31.250.10
POSTGRES_UPSTREAM_IP=172.31.250.11
NEXT_PUBLIC_SITE_URL=https://your-domain.ru

# ==============================================
# OAUTH - VK
# Create app at: https://vk.com/editapp?act=create
# Redirect URI: https://your-domain.ru/api/auth/callback/vk
# ==============================================
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ==============================================
# OAUTH - YANDEX
# Create app at: https://oauth.yandex.ru/
# Redirect URI: https://your-domain.ru/api/auth/callback/yandex
# ==============================================
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ==============================================
# YOOKASSA
# Webhook URL: https://your-domain.ru/api/payments/webhook
# ==============================================
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ==============================================
# EMAIL / SMTP
# ==============================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-mail@yandex.ru
SMTP_PASSWORD=APP_PASSWORD
SMTP_FROM="Azov Resort <your-mail@yandex.ru>"

# ==============================================
# ADMIN
# ==============================================
ADMIN_EMAIL=admin@your-domain.ru
