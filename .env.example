# ==============================================
# DATABASE
# ==============================================
POSTGRES_USER=azov_user
POSTGRES_PASSWORD=
POSTGRES_DB=azov_resort

# ==============================================
# NEXT.JS / AUTH
# ==============================================
NEXTAUTH_URL=https://azov.mak-o.ru
NEXTAUTH_SECRET=
# Generate with: openssl rand -base64 32

# ==============================================
# DIRECT DOMAIN / TLS
# ==============================================
APP_DOMAIN=azov.mak-o.ru
APP_NETWORK_SUBNET=172.31.250.0/24
APP_UPSTREAM_IP=172.31.250.10
POSTGRES_UPSTREAM_IP=172.31.250.11
NEXT_PUBLIC_SITE_URL=https://azov.mak-o.ru

# ==============================================
# OAUTH - VK
# Create app at: https://vk.com/editapp?act=create
# Redirect URI: https://your-domain.ru/api/auth/callback/vk
# ==============================================
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ==============================================
# OAUTH - YANDEX
# Create app at: https://oauth.yandex.ru/
# Redirect URI: https://your-domain.ru/api/auth/callback/yandex
# ==============================================
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ==============================================
# OAUTH - GOOGLE (Optional)
# ==============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==============================================
# EMAIL / SMTP
# ==============================================
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=ваша-почта@yandex.ru
SMTP_PASSWORD=APP_PASSWORD
SMTP_FROM="Отдых на Азове <3dsmaxer@mail.ru>"

# ==============================================
# ADMIN
# ==============================================
ADMIN_EMAIL=mako-play@mak-o.ru

# ==============================================
# VK ADMIN NOTIFICATIONS
# ==============================================
VK_GROUP_TOKEN=
VK_ADMIN_ID=
